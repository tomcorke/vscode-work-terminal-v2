{
  "name": "vscode-work-terminal-v2",
  "displayName": "Work Terminal",
  "description": "Work item kanban board with per-item tabbed terminals and AI agent integration",
  "publisher": "tomcorke",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "workTerminal.openPanel",
        "title": "Open Work Terminal",
        "category": "Work Terminal"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "work-terminal",
          "title": "Work Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "work-terminal": [
        {
          "id": "workTerminal.sidebarView",
          "name": "Work Items",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Work Terminal",
      "properties": {
        "workTerminal.taskBasePath": {
          "type": "string",
          "default": "2 - Areas/Tasks",
          "description": "Path containing task folders"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "node-pty": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@vscode/vsce": "^2.26.0"
  }
}
